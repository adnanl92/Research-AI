# ============================================================================
# WashU Research Assistant — environment variables
# Copy this file to .env.local and fill in the values.
# (DATABASE_URL also needs to be in a plain .env file so the Prisma CLI can
#  read it — `npm run db:push` handles both; see README.)
# ============================================================================

# ---- LLM backend -----------------------------------------------------------
# The app supports three interchangeable backends; the shared client
# (src/lib/llm/client.ts) picks one automatically, in this priority order:
#   - If all four AZURE_OPENAI_* vars are set  -> Azure AI Foundry (production)
#   - Else if OPENAI_API_KEY is set             -> OpenAI
#   - Else if ANTHROPIC_API_KEY is set          -> Anthropic Claude API
# Force a choice explicitly with LLM_PROVIDER=azure|openai|anthropic.

# Azure AI Foundry / Azure OpenAI (production target)
AZURE_OPENAI_ENDPOINT=            # e.g. https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=             # key from the Azure portal / AI Foundry
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=     # your model deployment name

# OpenAI (alternative backend, e.g. for local development)
OPENAI_API_KEY=                   # from platform.openai.com
OPENAI_MODEL=gpt-4.1-mini         # optional; defaults to gpt-4.1-mini

# Anthropic (alternative backend, e.g. for local development)
ANTHROPIC_API_KEY=                # from console.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-8   # optional; defaults to claude-opus-4-8

# LLM_PROVIDER=                   # optional: "azure" | "openai" | "anthropic"

# ---- Database --------------------------------------------------------------
DATABASE_URL="file:./dev.db"      # swap to a postgres:// URL in production
                                  # (and change provider to "postgresql" in
                                  #  prisma/schema.prisma — see README)

# ---- Auth ------------------------------------------------------------------
AUTH_SECRET=                      # generate with: openssl rand -base64 32

# ---- Scholarly APIs (all free; email/mailto = "polite pool" rate limits) ---
OPENALEX_MAILTO=you@wustl.edu     # any contact email; improves OpenAlex limits
SEMANTIC_SCHOLAR_API_KEY=         # optional but recommended, free signup at
                                  # https://www.semanticscholar.org/product/api
NCBI_API_KEY=                     # optional; raises PubMed limit to 10 req/s
                                  # https://www.ncbi.nlm.nih.gov/account/settings/
UNPAYWALL_EMAIL=you@wustl.edu     # required for open-access PDF resolution

# ---- Future: Microsoft Entra ID (WashU SSO) --------------------------------
# Leave blank until WashU IT provides these, then uncomment the provider
# block in src/lib/auth.ts (instructions are in that file and the README).
# AUTH_MICROSOFT_ENTRA_ID_ID=
# AUTH_MICROSOFT_ENTRA_ID_SECRET=
# AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=
